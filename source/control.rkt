      ensures  \\forall integer i; 0 &lt;= i &lt; n ==> a[i] == 0;
    */
    void set_to_zero(int* a, size_t n) {
      for (size_t i = 0; i &lt; n; i++) {
        /*@ invariant \\forall integer j; 0 &lt;= j &lt; i ==> a[j] == 0 */
