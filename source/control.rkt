(define Lam
  (case-lambda
    ((x e) (: $lambda x $. e))
    ((x t e) (Lam (&: x t) e))))
(define (RLabel x)
  (Mtext #:attr* '((class "small-caps")) x))
(define (&rule #:space [n 8] . j*)
  (let-values (((j* j1) (split-at-right j* 1)))
    (~ #:attr* '((displaystyle "true"))
       (apply (&split n) j*) (car j1))))
(define (&rull label . x*)
  (if label
      (: (apply &rule x*) label)
      (apply &rule x*)))
(define $!- (Mo "&vdash;"))
(define (!- . x*)
  (let-values (((a* b*) (split-at-right x* 1)))
    (: (apply &cm a*) $!- (car b*))))
(define (G!- . x*)
  (apply !- Γ x*))
(define (LP label #:attr* [attr* '()] . x*)
