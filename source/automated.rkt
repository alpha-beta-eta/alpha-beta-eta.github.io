(define $phiv (Mi "&phiv;"))
(define (qstroke x A B)
  (: A (_ $\| x) B))
(define (subst-eval x q p v)
  (&= (&eval (@psubst x q p) v)
      (&eval p (@ext v x (&eval q v)))))
(define Γ $Gamma:normal)
(define Δ $Delta:normal)
(define (deriv^ x . y*)
  (set-attr*
   (apply
    Mtable
    (Mtr (Mtd $) (Mtd x))
    (map (lambda (y)
           (Mtr (Mtd $=) (Mtd y)))
         y*))
   'columnalign "center left"))
