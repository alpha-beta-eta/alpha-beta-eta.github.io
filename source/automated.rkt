(define $& (Mo "&amp;"))
(define $\| (Mo "|"))
(define $<-> (Mo "&harr;"))
(define $--> (Mo "&xrarr;"))
(define $!= (Mo "&vDash;"))
(define (!= . x*)
  (let-values (((a* b*) (split-at-right x* 1)))
