val fm : prop formula = &lt;&lt;(p \\/ q /\\ r) /\\ (~p \\/ ~r)>>
# dnf fm;;
- : prop formula = &lt;&lt;~p /\\ q /\\ r \\/ p /\\ ~q /\\ ~r \\/ p /\\ q /\\ ~r>>"))
