(define $.
  (Mo "." #:attr* '((lspace "0"))))
(define (∃ . x*)
  (let-values (((x* P*) (split-at-right x* 1)))
    (: $exists (apply : x*) $. (car P*))))
(define (∀ . x*)
  (let-values (((x* P*) (split-at-right x* 1)))
    (: $forall (apply : x*) $. (car P*))))
(define $exists!
  (Mo "&exist;!" #:attr* '((lspace "0") (rspace "0"))))
(define (∃! . x*)
