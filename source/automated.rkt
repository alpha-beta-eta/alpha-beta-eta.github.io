;&lt;term> ::= &lt;var> | (&lt;func> &lt;term>*)
;&lt;predicate> ::= (&lt;pred> &lt;term>*)
;&lt;exp> ::= &lt;bool>
;       |  &lt;predicate>
;       |  (not &lt;exp>)
;       |  (and &lt;exp> &lt;exp>)
;       |  (or &lt;exp> &lt;exp>)
;       |  (=> &lt;exp> &lt;exp>)
;       |  (&lt;=> &lt;exp> &lt;exp>)
