      "而且也容易映射回实际的公式. "
      "现在我们可以按如下方式写下DNF函数, "
      "使用OCaml列表表示集合, "
      "但是要注意在构造时避免重复:"
      (CodeB "let distrib s1 s2 = setify(allpairs union s1 s2);;

let rec purednf fm =
  match fm with
    And(p,q) -> distrib (purednf p) (purednf q)
  | Or(p,q) -> union (purednf p) (purednf q)
  | _ -> [[fm]];;")
