val fm : prop formula = &lt;&lt;(p \\/ q /\\ r) /\\ (~p \\/ ~r)>>
# dnf fm;;
- : prop formula = &lt;&lt;p /\\ ~r \\/ q /\\ r /\\ ~p>>
