(define $Disj (Mo "&Vee;"))
(define $Conj (Mo "&Wedge;"))
(define-bigop*
  (Disj $Disj)
  (Conj $Conj))
(define (_prime A x)
  (_^ A x $prime))
(define (|[;]| . x*)
  (bra0 (apply &\; x*)))
(define (_cm A . x*)
