   ((Definition)
    "出现在一个项" $t "里的常量的集合, 记作"
    (&Consts $t) ", 定义如下:"
    (MB (set-attr*
         (&Table
          ((&Consts $true) $= (setE $true))
          ((&Consts $false) $= (setE $false))
          ((&Consts $zero) $= (setE $zero))
          ((&Consts (&succ $t_1))
           $= (&Consts $t_1))
          ((&Consts (&pred $t_1))
           $= (&Consts $t_1))
          ((&Consts (&iszero $t_1))
           $= (&Consts $t_1))
          ((&Consts (If $t_1 $t_2 $t_3))
           $=
           (&union (&Consts $t_1)
                   (&Consts $t_2)
                   (&Consts $t_3))))
         'columnalign "left")))
   (P "可由归纳定义所计算的项的另一性质是其"
      (Em "大小") ".")
   ((Definition)
    "一个项" $t "的" (Em "大小") ", 记作"
    (&size $t) ", 定义如下:"
    (MB (set-attr*
         (&Table
          ((&size $true) $= $1)
          ((&size $false) $= $1)
          ((&size $zero) $= $1)
          ((&size (&succ $t_1))
           $= (&+ (&size $t_1) $1))
          ((&size (&pred $t_1))
           $= (&+ (&size $t_1) $1))
          ((&size (&iszero $t_1))
           $= (&+ (&size $t_1) $1))
          ((&size (If $t_1 $t_2 $t_3))
           $=
           (&+ (&size $t_1) (&size $t_2)
               (&size $t_3) $1)))
         'columnalign "left"))
    "也就是说, " $t "的大小是其抽象句法树的结点数目. "
    "类似地, 一个项" $t "的" (Em "深度") ", 记作"
    (&depth $t) ", 定义如下:"
    (MB (set-attr*
         (&Table
          ((&depth $true) $= $1)
          ((&depth $false) $= $1)
          ((&depth $zero) $= $1)
          ((&depth (&succ $t_1))
           $= (&+ (&depth $t_1) $1))
          ((&depth (&pred $t_1))
           $= (&+ (&depth $t_1) $1))
          ((&depth (&iszero $t_1))
           $= (&+ (&depth $t_1) $1))
          ((&depth (If $t_1 $t_2 $t_3))
           $=
           (&+ (&max (&depth $t_1)
                     (&depth $t_2)
                     (&depth $t_3))
               $1)))
         'columnalign "left"))
    "等价地, " (&depth $t) "是使得" (∈ $t $S_i)
    "的" $i "之中最小的那个, 而" $S_i "的定义见"
    (Ref "terms-concretely") ".")
   (P "下面是一个归纳证明, 证明的是关于一个项中常量数目与其大小之间的一个简单事实. "
      "(当然, 这个性质本身是完全显而易见的. 有趣的是这个归纳证明的形式, "
      "我们在后续内容中将会反复看到这一形式.)")
   ((Lemma)
    "一个项" $t "中不同常量的数目不大于" $t "的大小, 即"
    (&<= (&card (&Consts $t)) (&size $t)) ".")
   ((proof)
    "根据" $t "的深度上的归纳. 假设想要的性质对于所有深度小于"
    $t "的项成立, 我们必须要证明其对于" $t "自身成立. "
    "以下是三种需要考虑的情形:"
    (Ul (Li "情形: " $t "是一个常量" (Br)
            "立即可以推出: "
            (&= (&card (&Consts $t))
                (&card (setE $t))
                $1 (&size $t)) ".")
        (Li "情形: " $t "等于"
            (&succ $t_1) ", " (&pred $t_1) "或" (&iszero $t_1) (Br)
            "根据归纳假设, "
            (&<= (&card (&Consts $t_1)) (&size $t_1))
            ". 现在我们可以按照如下方式进行计算: "
            (: (&card (&Consts $t)) $=
               (&card (&Consts $t_1)) $<=
               (&size $t_1) $<
               (&size $t)) ".")
        (Li "情形: " (&= $t (If $t_1 $t_2 $t_3)) (Br)
            "根据归纳假设, "
            (&<= (&card (&Consts $t_1)) (&size $t_1)) ", "
            (&<= (&card (&Consts $t_2)) (&size $t_2)) ", "
            (&<= (&card (&Consts $t_3)) (&size $t_3))
            ". 现在我们可以按照如下方式进行计算: "
            (MB (deriv0
                 (&card (&Consts $t))
                 $=
                 (&card (&union (&Consts $t_1)
                                (&Consts $t_2)
                                (&Consts $t_3)))
                 $<=
                 (&+ (&card (&Consts $t_1))
                     (&card (&Consts $t_2))
                     (&card (&Consts $t_3)))
                 $<=
                 (&+ (&size $t_1)
                     (&size $t_2)
                     (&size $t_3))
                 $<
                 (&size $t))))))
   (P "这个证明的形式可以通过将其重新表述为某个一般性推理原理来加以澄清. "
      "为了更加完整, 我们还纳入了两个在关于项的证明中经常使用的类似原理.")
   ((Theorem)
    (B "[项上的归纳原理]: ")
    "设" $P "是项上的一个谓词."
    (Blockquote
     (Pre "深度上的归纳:
  如果对于每个项" $s ",
    假设对于所有满足"
           (&< (&depth $r) (&depth $s))
           "的项" $r "都有" (app $P $r)
           "成立的情况下
    我们可以证明" (app $P $s) "成立,
  那么" (app $P $s) "对于所有的" $s "成立.

大小上的归纳:
  如果对于每个项" $s ",
    假设对于所有满足"
           (&< (&size $r) (&size $s))
           "的项" $r "都有" (app $P $r)
           "成立的情况下
    我们可以证明" (app $P $s) "成立,
  那么" (app $P $s) "对于所有的" $s "成立.

结构归纳:
  如果对于每个项" $s ",
    假设对于" $s "的所有立即子项" $r
          "都有" (app $P $r) "成立的情况下
    我们可以证明" (app $P $s) "成立,
  那么" (app $P $s) "对于所有的" $s "成立.")))
   ((proof)
    "留作练习.")
   
   (H3. "语义风格")
