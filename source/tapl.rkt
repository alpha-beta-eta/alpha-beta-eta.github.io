    "考虑以下三元素宇宙" (&= $U:script (setE $a $b $c))
    "上的生成函数:"
    (let ((E1 (λ X (app $E_1 (apply setE X)))))
      (MB (set-attr*
           (&Table
            ((app $E_1 $empty) $= (setE $c) (E1 $a $b) $= (setE $c))
            ((E1 $a) $= (setE $c) (E1 $a $c) $= (setE $b $c))
            ((E1 $b) $= (setE $c) (E1 $b $c) $= (setE $a $b $c))
            ((E1 $c) $= (setE $b $c) (E1 $a $b $c) $= (setE $a $b $c)))
           'columnalign "left")))
    "那么只有一个" $E_1 "-封闭集合, 即" (setE $a $b $c)
    ", 以及四个" $E_1 "-一致集合, 即" $empty ", " (setE $c)
    ", " (setE $b $c) ", " (setE $a $b $c) "." (Br)
    $E_1 "可由以下" (Em "推理规则") "集合紧凑表示:"
