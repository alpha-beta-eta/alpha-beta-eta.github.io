                (Li "对于每个" $V "中向量" $alpha ", 存在唯一的"
                    $V "中向量" (&- $alpha) "满足"
                    (&= (&+ $alpha (@- $alpha)) $0) ";")))
        (Li "一种法则 (或者说运算), 被称为标量乘法, 联系每个" $F
            "中标量" $c "和" $V "中向量" $alpha
            "以一个" $V "中向量" (&i* $c $alpha) ", 其被称为"
            $c "和" $alpha "之积, 并且该运算满足"
            (Ol #:attr* '((type "a"))
                (Li (&= (&i* $1 $alpha) $alpha) "对于每个"
                    $V "中的" $alpha "成立;")
                (Li (assoc* $c_1 $c_2 $alpha) ";")
                (Li (disR $c $alpha $beta) ";")
                (Li (disL $c_1 $c_2 $alpha) ".")))))
