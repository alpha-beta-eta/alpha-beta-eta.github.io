    ", 其中" (&< $i $j) ". 如果" (&= $j (&+ $i $1)) ", 那么" $A "有相等的邻行, 于是"
    (&= (app $D $A) $0) ". 如果" (&> $j (&+ $i $1)) ", 我们交换"
    (_ $alpha (&+ $i $1)) "和" $alpha_j ", 其结果" $B "拥有相等的邻行, 于是"
    (&= (app $D $B) $0) ". 从另一方面说, " (&= (app $D $B) (&- (app $D $A)))
