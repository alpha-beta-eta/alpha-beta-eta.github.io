                      (&i* (mref (&adj $A) $j $i) $y_i))
                 (sum (&= $i $1) $n
                      (&i* (^ (@ $-1) (&+ $i $j))
                           $y_i
                           (ap $det (bra0 (subm $A $i $j)))))
